<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xxl.boot.admin.plugin.ai.mapper.KbInfoMapper">

    <resultMap id="KbInfo" type="com.xxl.boot.admin.plugin.ai.model.KbInfo" >
        <result column="id" property="id" />
        <result column="kb_name" property="kbName" />
        <result column="kb_desc" property="kbDesc" />
        <result column="embedding_model" property="embeddingModel" />
        <result column="vector_db_type" property="vectorDbType" />
        <result column="collection_name" property="collectionName" />
        <result column="add_time" property="addTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="Base_Column_List">
        t.`id`,
        t.`kb_name`,
        t.`kb_desc`,
        t.`embedding_model`,
        t.`vector_db_type`,
        t.`collection_name`,
        t.`add_time`,
        t.`update_time`
    </sql>

    <insert id="insert" parameterType="java.util.Map" >
        INSERT INTO xxl_boot_ai_kb_info (
            `kb_name`,
            `kb_desc`,
            `embedding_model`,
            `vector_db_type`,
            `collection_name`,
            `add_time`,
            `update_time`
        )
        VALUES(
                  #{kbInfo.kbName} ,
                  #{kbInfo.kbDesc} ,
                  #{kbInfo.embeddingModel} ,
                  #{kbInfo.vectorDbType} ,
                  #{kbInfo.collectionName} ,
                  NOW() ,
                  NOW()
              )
    </insert>

    <delete id="delete" parameterType="java.util.Map" >
        DELETE FROM xxl_boot_ai_kb_info
        WHERE `id` in
        <foreach collection="ids" item="item" open="(" close=")" separator="," >
            #{item}
        </foreach>
    </delete>

    <update id="update" parameterType="java.util.Map" >
        UPDATE xxl_boot_ai_kb_info
        SET
            `kb_name` = #{kbInfo.kbName},
            `kb_desc` = #{kbInfo.kbDesc},
            `embedding_model` = #{kbInfo.embeddingModel},
            `vector_db_type` = #{kbInfo.vectorDbType},
            <!-- `collection_name` = #{kbInfo.collectionName}, -->
            `update_time` = NOW()
        WHERE `id` = #{kbInfo.id}
    </update>

    <select id="load" parameterType="java.util.Map" resultMap="KbInfo">
        SELECT <include refid="Base_Column_List" />
        FROM xxl_boot_ai_kb_info AS t
        WHERE t.`id` = #{id}
    </select>

    <select id="pageList" parameterType="java.util.Map" resultMap="KbInfo">
        SELECT <include refid="Base_Column_List" />
        FROM xxl_boot_ai_kb_info AS t
        <trim prefix="WHERE" prefixOverrides="AND | OR" >
            <if test="kbName != null and kbName != ''">
                AND t.`kb_name` like CONCAT(CONCAT('%', #{kbName}), '%')
            </if>
        </trim>
        LIMIT #{offset}, #{pagesize}
    </select>

    <select id="pageListCount" parameterType="java.util.Map" resultType="int">
        SELECT count(1)
        FROM xxl_boot_ai_kb_info AS t
        <trim prefix="WHERE" prefixOverrides="AND | OR" >
            <if test="kbName != null and kbName != ''">
                AND t.`kb_name` like CONCAT(CONCAT('%', #{kbName}), '%')
            </if>
        </trim>
    </select>

</mapper>
