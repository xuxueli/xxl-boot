<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xxl.boot.admin.plugin.ai.mapper.KbDocumentMapper">

    <resultMap id="KbDocument" type="com.xxl.boot.admin.plugin.ai.model.KbDocument" >
        <result column="id" property="id" />
        <result column="kb_id" property="kbId" />
        <result column="doc_name" property="docName" />
        <result column="doc_type" property="docType" />
        <result column="content" property="content" />
        <result column="file_url" property="fileUrl" />
        <result column="status" property="status" />
        <result column="add_time" property="addTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="Base_Column_List">
        t.`id`,
        t.`kb_id`,
        t.`doc_name`,
        t.`doc_type`,
        t.`content`,
        t.`file_url`,
        t.`status`,
        t.`add_time`,
        t.`update_time`
    </sql>

    <insert id="insert" parameterType="java.util.Map" >
        INSERT INTO xxl_boot_ai_kb_document (
            `kb_id`,
            `doc_name`,
            `doc_type`,
            `content`,
            `file_url`,
            `status`,
            `add_time`,
            `update_time`
        )
        VALUES(
                  #{kbDocument.kbId} ,
                  #{kbDocument.docName} ,
                  #{kbDocument.docType} ,
                  #{kbDocument.content} ,
                  #{kbDocument.fileUrl} ,
                  #{kbDocument.status} ,
                  NOW() ,
                  NOW()
              )
    </insert>

    <delete id="delete" parameterType="java.util.Map" >
        DELETE FROM xxl_boot_ai_kb_document
        WHERE `id` in
        <foreach collection="ids" item="item" open="(" close=")" separator="," >
            #{item}
        </foreach>
    </delete>

    <update id="update" parameterType="java.util.Map" >
        UPDATE xxl_boot_ai_kb_document
        SET
            `kb_id` = #{kbDocument.kbId},
            `doc_name` = #{kbDocument.docName},
            `doc_type` = #{kbDocument.docType},
            `content` = #{kbDocument.content},
            `file_url` = #{kbDocument.fileUrl},
            `status` = #{kbDocument.status},
            `update_time` = NOW()
        WHERE `id` = #{kbDocument.id}
    </update>

    <select id="load" parameterType="java.util.Map" resultMap="KbDocument">
        SELECT <include refid="Base_Column_List" />
        FROM xxl_boot_ai_kb_document AS t
        WHERE t.`id` = #{id}
    </select>

    <select id="pageList" parameterType="java.util.Map" resultMap="KbDocument">
        SELECT <include refid="Base_Column_List" />
        FROM xxl_boot_ai_kb_document AS t
        LIMIT #{offset}, #{pagesize}
    </select>

    <select id="pageListCount" parameterType="java.util.Map" resultType="int">
        SELECT count(1)
        FROM xxl_boot_ai_kb_document AS t
    </select>

    <select id="queryByKbId" parameterType="java.util.Map" resultMap="KbDocument">
        SELECT <include refid="Base_Column_List" />
        FROM xxl_boot_ai_kb_document AS t
        WHERE t.`kb_id` = #{kbId}
    </select>

    <update id="updateStatusByKbId" parameterType="java.util.Map">
        UPDATE xxl_boot_ai_kb_document
        SET
            `status` = #{status},
            `update_time` = NOW()
        WHERE `kb_id` = #{kbId}
    </update>

</mapper>
